# ── Database ───────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@host/dbname

# ── Admin credentials ─────────────────────────────────────────────────────────
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-to-something-strong

# ── JWT session secret (min 32 characters) ────────────────────────────────────
SESSION_SECRET=replace-with-a-random-32-plus-char-string

# ── Upstash Redis (rate limiting) ─────────────────────────────────────────────
# Create a free database at https://console.upstash.com/
# Copy the REST URL and token from the database details page.
UPSTASH_REDIS_REST_URL=https://your-db.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-token-here
